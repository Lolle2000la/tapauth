# TapAuth PAM Messages – English (en)
pam-waiting-tap-skip = TapAuth: Waiting for phone tap (press Enter to skip)...
pam-waiting-tap = TapAuth: Waiting for phone tap...
pam-cannot-connect = TapAuth: Cannot connect to daemon, trying password...
pam-communication-error = TapAuth: Communication error, trying password...
pam-connection-lost = TapAuth: Connection lost, trying password...
pam-timed-out = TapAuth: Timed out, trying password...
pam-skipped = TapAuth: Skipped, trying password...
pam-auth-successful = TapAuth: Authentication successful!
pam-auth-denied = TapAuth: Authentication denied by server
pam-error-prefix = TapAuth: Error -
