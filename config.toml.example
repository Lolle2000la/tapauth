# TapAuth Configuration
# Place this file at /etc/tapauth/config.toml
# All settings are optional - defaults will be used if not specified

# PAM Module Settings
# Timeout for individual PAM operations (connect, send, receive) in seconds.
# This prevents PAM module hangs if the daemon is unresponsive.
# The authentication session on the phone can continue for up to 120 seconds,
# but PAM operations will timeout after this duration to prevent user lockouts.
# Default: 3
pam_operation_timeout_secs = 3
